{
  "name": "pr-dependency-graph-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "generate": "genql --endpoint https://api.github.com/graphql --output ./src/generated -H \"Authorization: bearer $GITHUB_TOKEN\" -H \"User-Agent: pr-dependency-graph\" && node scripts/fix-esm-imports.cjs"
  },
  "dependencies": {
    "@genql/runtime": "^2.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@genql/cli": "^6.3.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
